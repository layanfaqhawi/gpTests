generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model ConceptCard {
  id           String      @id 
  term         String
  definition   String
  category     String
  aliases      Alias[]
  opposites    Opposite[]
  facts        Fact[]
  tags         Tag[]
  difficulty   String
  version      Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Alias {
  id            String      @id @default(cuid())
  value         String
  conceptCard   ConceptCard @relation(fields: [conceptCardId], references: [id])
  conceptCardId String
}

model Opposite {
  id            String      @id @default(cuid())
  value         String
  conceptCard   ConceptCard @relation(fields: [conceptCardId], references: [id])
  conceptCardId String
}

model Fact {
  id            String      @id @default(cuid())
  value         String
  conceptCard   ConceptCard @relation(fields: [conceptCardId], references: [id])
  conceptCardId String
}

model Tag {
  id            String      @id @default(cuid())
  value         String
  conceptCard   ConceptCard @relation(fields: [conceptCardId], references: [id])
model ConceptCard {
    id         String   @id
    term       String
    definition String
    category   String
    aliases    Json
    opposites  Json
    facts      Json
    tags       Json
    difficulty String
    version    Int
    createdAt  DateTime @default(now())
    updatedAt  DateTime @updatedAt
}
