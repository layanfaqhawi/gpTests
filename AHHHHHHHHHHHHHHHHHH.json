{
  "configType": "quiz",
  "version": "1",
  "id": "connected to the id within the database",
  "instructions": "any specific instructions for the quiz",
  "duration": "time allowed (in seconds) before autosubmission",
  "endDate": "date-time when the quiz closes",
  "navigationType": "ONE_WAY | FREE",
  "attemptsAllowed": "number of attempts allowed for the quiz",
  "reviewAllowed": "true if the quiz can be reviewed after submission",
  "questions": [
    {
      "questionId": "id of a QuestionConfig",
      "order": "display order of the question in the quiz"
    }
  ]
}

{
  "configType": "question",
  "version": "1",
  "id": "connected to the id within the database",
  "generator": {
    "generatorConfigId": "id of generator config (e.g., gen_dag_graph)",
    "inputs": {
      "nodes": "number of nodes",
      "edges": "number of edges"
    },
    "outputs": {
      "instance": "name of the produced instance output"
    }
  },
  "solvers": [
    {
      "solverConfigId": "id of solver config",
      "inputs": {
        "instance": "name of input instance",
        "previous": "name of previous solver output (optional)"
      },
      "outputs": {
        "solution": "name of produced solution output"
      }
    }
  ],
  "grader": {
    "graderConfigId": "id of grader config",
    "inputs": {
      "solution": "name of solver output to grade",
      "answer": "name of student solution output to grade"
    },
    "outputs": {
      "grade": "name of produced grade output"
    }
  }
}

{
  "configType": "generator",
  "version": "1",
  "type": "graph",
  "data": {
    "id": "connected to the id within the database",
    "directed": "true if the graph is directed",
    "weighted": "true if the graph is weighted",
    "cyclic": "true if the graph is cyclic",
    "connected": "true if the graph is undirected and connected or if the graph is directed and strongly connected"
  }
}

{
  "configType": "generator",
  "version": "1",
  "type": "function",
  "data": {
    "id": "connected to the id within the database",
    "family": "this is the family from above",
    "nID": "id of another function generator config used as n (optional)",
    "allowedParameters": {
      "c": "true if constant is allowed",
      "b": "true if logarithmic base is allowed",
      "e": "true if logarithmic power is allowed",
      "p": "true if polynomial/root power or denominator is allowed",
      "num": "true if root numerator is allowed",
      "a": "true if exponential base is allowed",
      "k": "true if factorial coefficient is allowed"
    }
  }
}

{
  "configType": "generator",
  "version": "1",
  "type": "recurrence",
  "data": {
    "id": "connected to the id within the database",
    "form": "the form of the recurrence ex-> aT(n/b) + f(n)",
    "functionGeneratorConfigId": "id of the function generator config used to generate f(n)"
  }
}

{
  "configType": "generator",
  "version": "1",
  "type": "loop",
  "data": {
    "id": "connected to the id within the database",
    "allowedVariables": ["variable name", "variable name"],
    "allowedSteps": ["+=1", "*=2"],
    "allowedDependencies": ["INDEPENDENT", "DEPENDENT_PARENT", "DEPENDENT_PREVIOUS"],
    "allowedChildNodeTypes": ["LOOP", "FUNCTION", "OPERATION"],
    "structureRules": {
      "allowAdjacentLoops": "true if multiple top-level loops are allowed",
      "allowNestedLoops": "true if loops can be nested",
      "maxDepthLimit": "global safety cap on nesting depth",
      "maxSiblingsLimit": "global safety cap on siblings per level"
    },
    "boundsPolicy": {
      "allowedStartForms": ["0", "1", "c"],
      "allowedEndForms": ["n", "n^2", "logn", "c"],
      "allowSymbolicN": "true if symbolic bounds are allowed"
    }
  }
}

